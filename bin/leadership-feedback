#!/usr/bin/env bash
# leadership-feedback — pipe a Slack thread or message through the leadership-feedback skill.
# Copies result to clipboard, shows a notification, and appends to leadership-log.md.
#
# Usage:
#   pbpaste | bin/leadership-feedback
#   cat thread.txt | bin/leadership-feedback
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
DATA_ROOT="${GROWTH_REPO:-$REPO_ROOT/../engineering-notes}"
LOG_FILE="$DATA_ROOT/leadership-log.md"

INPUT=$(cat)
if [[ -z "$INPUT" ]]; then
  echo "Error: no input text" >&2
  exit 1
fi

SKILL_BODY=$(awk 'BEGIN{c=0} /^---$/{c++;next} c>=2{print}' "$REPO_ROOT/.claude/skills/leadership-feedback.md")
RESULT=$(printf '%s' "$INPUT" | claude -p --system-prompt "$SKILL_BODY" --tools "")
printf '%s' "$RESULT" | pbcopy

# Append to leadership log in engineering-notes
mkdir -p "$DATA_ROOT"
TIMESTAMP=$(date +"%Y-%m-%d %H:%M")
printf '\n---\n\n### %s\n\n%s\n' "$TIMESTAMP" "$RESULT" >> "$LOG_FILE"

afplay /System/Library/Sounds/Glass.aiff &
osascript -e 'display notification "Leadership analysis copied to clipboard and saved to log." with title "Leadership Feedback"' &
