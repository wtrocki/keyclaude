#!/usr/bin/env bash
# Usage: pbpaste | bin/leadership-feedback
set -euo pipefail

DATA_ROOT="${GROWTH_REPO:-$HOME/notes/data}"
LOG_FILE="$DATA_ROOT/leadership-log.md"

INPUT=$(cat)
[[ -z "$INPUT" ]] && { echo "Error: no input text" >&2; exit 1; }

RESULT=$(printf '%s' "$INPUT" | claude -p "/leadership-feedback")
printf '%s' "$RESULT" | pbcopy

mkdir -p "$DATA_ROOT"
printf '\n---\n\n### %s\n\n%s\n' "$(date +"%Y-%m-%d %H:%M")" "$RESULT" >> "$LOG_FILE"

afplay /System/Library/Sounds/Glass.aiff &
osascript -e 'display notification "Leadership analysis copied to clipboard and saved to log." with title "Leadership Feedback"' &
