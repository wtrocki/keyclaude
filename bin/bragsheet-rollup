#!/usr/bin/env bash
# bragsheet-rollup — scan weekly notes for ## Bragsheet Signal sections and collect rows.
# Extracts all table rows (lines starting with |) from each note's Bragsheet Signal section.
#
# Usage:
#   bin/bragsheet-rollup                           # print rows to stdout
#   bin/bragsheet-rollup --since 2026-W01          # only notes from this week onward
#   bin/bragsheet-rollup --append-file docs/bragsheet.md
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
DATA_ROOT="${GROWTH_REPO:-$REPO_ROOT/docs}"
WEEKLY_DIR="$DATA_ROOT/weekly"
APPEND_FILE=""
SINCE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --since) SINCE="$2"; shift 2 ;;
    --append-file) APPEND_FILE="$2"; shift 2 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

extract_signal_rows() {
  local file="$1"
  awk '/^## Bragsheet Signal/{found=1; next} found && /^## /{exit} found && /^\|/{print}' "$file"
}

ROWS=""
for file in "$WEEKLY_DIR"/[0-9][0-9][0-9][0-9]-W[0-9]*.md; do
  [[ -f "$file" ]] || continue
  week=$(basename "$file" .md)
  [[ -n "$SINCE" && "$week" < "$SINCE" ]] && continue
  row=$(extract_signal_rows "$file")
  if [[ -n "$row" ]]; then
    ROWS+="$row"$'\n'
  fi
done

if [[ -z "$ROWS" ]]; then
  echo "No bragsheet rows found in $WEEKLY_DIR" >&2
  exit 0
fi

if [[ -n "$APPEND_FILE" ]]; then
  printf '%s\n' "$ROWS" >> "$APPEND_FILE"
  echo "Appended $(echo "$ROWS" | grep -c '^|' || true) row(s) to $APPEND_FILE" >&2
else
  printf '%s\n' "$ROWS"
fi
