#!/usr/bin/env bash
# Usage: echo "draft text" | bin/rewrite [default|leadership|external]
set -euo pipefail
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

DATA_ROOT="${GROWTH_REPO:-$HOME/notes/data}"
LOG_FILE="$DATA_ROOT/writing-insights.md"
MODE="${1:-default}"

INPUT=$(cat)
[[ -z "$INPUT" ]] && { echo "Error: no input text" >&2; exit 1; }

case "$MODE" in
  default|leadership|external) ;;
  *) echo "Unknown mode: $MODE (valid: default, leadership, external)" >&2; exit 1 ;;
esac

RESULT=$(printf '[mode: %s]\n%s' "$MODE" "$INPUT" | claude -p "/rewrite-inline")
printf '%s' "$RESULT" | pbcopy

afplay /System/Library/Sounds/Glass.aiff &
osascript -e 'display notification "Rewritten text copied to clipboard." with title "Rewrite"' &

(
  INSIGHTS=$(printf '## Original\n%s\n\n## Rewritten\n%s' "$INPUT" "$RESULT" | claude -p "/writing-insights")
  mkdir -p "$(dirname "$LOG_FILE")"
  TIMESTAMP=$(date +"%Y-%m-%d %H:%M")
  ORIGINAL_PREVIEW=$(printf '%s' "$INPUT" | head -c 300)
  [[ ${#INPUT} -gt 300 ]] && ORIGINAL_PREVIEW="${ORIGINAL_PREVIEW}…"
  printf '\n---\n\n### %s [%s]\n\n**Original:** %s\n\n**Writing hints:**\n%s\n' \
    "$TIMESTAMP" "$MODE" "$ORIGINAL_PREVIEW" "$INSIGHTS" >> "$LOG_FILE"
) &
