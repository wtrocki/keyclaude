#!/usr/bin/env bash
# rewrite — pipe selected text through the rewrite-inline skill, copy result to clipboard.
# Also logs writing improvement hints to $GROWTH_REPO/data/writing-insights.md in the background.
#
# Usage:
#   echo "draft text" | bin/rewrite [mode]
#   pbpaste | bin/rewrite leadership
#
# Modes: default (default), leadership, external
set -euo pipefail
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
DATA_ROOT="${GROWTH_REPO:-$REPO_ROOT/../engineering-notes}"
LOG_FILE="$DATA_ROOT/data/writing-insights.md"
MODE="${1:-default}"

INPUT=$(cat)
if [[ -z "$INPUT" ]]; then
  echo "Error: no input text" >&2
  exit 1
fi

case "$MODE" in
  default|leadership|external) ;;
  *) echo "Unknown mode: $MODE (valid: default, leadership, external)" >&2; exit 1 ;;
esac

if [[ "$MODE" == "default" ]]; then
  PROMPT="$INPUT"
else
  PROMPT="[mode: $MODE]
$INPUT"
fi

cd "$REPO_ROOT"
SKILL_BODY=$(awk 'BEGIN{c=0} /^---$/{c++;next} c>=2{print}' "$REPO_ROOT/.claude/skills/rewrite-inline.md")
RESULT=$(printf '%s' "$PROMPT" | claude -p --system-prompt "$SKILL_BODY" --tools "")
printf '%s' "$RESULT" | pbcopy

afplay /System/Library/Sounds/Glass.aiff &
osascript -e 'display notification "Rewritten text copied to clipboard." with title "Rewrite"' &

# Background: extract transferable writing patterns and append to insights log
(
  INSIGHT_BODY=$(awk 'BEGIN{c=0} /^---$/{c++;next} c>=2{print}' "$REPO_ROOT/.claude/skills/writing-insights.md")

  INSIGHT_INPUT="## Original
$INPUT

## Rewritten
$RESULT"

  INSIGHTS=$(printf '%s' "$INSIGHT_INPUT" | claude -p --system-prompt "$INSIGHT_BODY" --tools "")

  mkdir -p "$(dirname "$LOG_FILE")"
  TIMESTAMP=$(date +"%Y-%m-%d %H:%M")
  ORIGINAL_PREVIEW=$(printf '%s' "$INPUT" | head -c 300)
  [[ ${#INPUT} -gt 300 ]] && ORIGINAL_PREVIEW="${ORIGINAL_PREVIEW}…"

  printf '\n---\n\n### %s [%s]\n\n**Original:** %s\n\n**Writing hints:**\n%s\n' \
    "$TIMESTAMP" "$MODE" "$ORIGINAL_PREVIEW" "$INSIGHTS" >> "$LOG_FILE"
) &
