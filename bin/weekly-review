#!/usr/bin/env bash
# Usage: bin/weekly-review [YYYY-WNN]
set -euo pipefail

DATA_ROOT="${GROWTH_REPO:-$HOME/notes/data}"
WEEKLY_DIR="$DATA_ROOT/weekly"
WEEK="${1:-$(date +"%Y-W%V")}"
FILE="$WEEKLY_DIR/${WEEK}.md"

[[ ! -f "$FILE" ]] && { echo "Error: weekly note not found: $FILE" >&2; echo "Run 'bin/weekly-init ${WEEK}' to create it." >&2; exit 1; }

SYNTHESIS=$(claude -p "/weekly-review" < "$FILE")
printf '%s\n' "$SYNTHESIS"

if ! grep -q "^## Weekly Review" "$FILE"; then
  printf '\n## Weekly Review\n\n%s\n' "$SYNTHESIS" >> "$FILE"
  echo "Appended to: $FILE" >&2
fi
