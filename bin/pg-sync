#!/usr/bin/env bash
# pg-sync — synthesize the bragsheet and cycle notes into a P&G self-reflection draft.
#
# Usage:
#   bin/pg-sync                                              # uses bragsheet.md + latest cycle
#   bin/pg-sync --cycle 2026-Q2                             # specific cycle file
#   bin/pg-sync --output-file docs/growth/cycles/2026-Q2.md
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
DATA_ROOT="${GROWTH_REPO:-$REPO_ROOT/docs}"
BRAGSHEET="$DATA_ROOT/bragsheet.md"
CYCLES_DIR="$DATA_ROOT/growth/cycles"
OUTPUT_FILE=""
CYCLE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --cycle) CYCLE="$2"; shift 2 ;;
    --bragsheet) BRAGSHEET="$2"; shift 2 ;;
    --output-file) OUTPUT_FILE="$2"; shift 2 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

if [[ ! -f "$BRAGSHEET" ]]; then
  echo "Bragsheet not found: $BRAGSHEET" >&2
  exit 1
fi

if [[ -n "$CYCLE" ]]; then
  CYCLE_FILE="$CYCLES_DIR/${CYCLE}.md"
else
  CYCLE_FILE=$(ls -t "$CYCLES_DIR"/*.md 2>/dev/null | head -1 || true)
fi

if [[ -z "$CYCLE_FILE" || ! -f "$CYCLE_FILE" ]]; then
  echo "No cycle file found in $CYCLES_DIR — create one first or pass --cycle YYYY-QN." >&2
  exit 1
fi

INPUT=$(printf '## Bragsheet\n\n%s\n\n## Cycle Notes\n\n%s' \
  "$(cat "$BRAGSHEET")" \
  "$(cat "$CYCLE_FILE")")

if [[ -n "$OUTPUT_FILE" ]]; then
  printf '%s' "$INPUT" | claude -p --profile pg-sync-agent --output-file "$OUTPUT_FILE"
  echo "Written to $OUTPUT_FILE" >&2
else
  printf '%s' "$INPUT" | claude -p --profile pg-sync-agent
fi
