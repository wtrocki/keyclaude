#!/usr/bin/env bash
# review-agent — run a Staff-level code or design review via the reviewer-agent profile.
#
# Usage:
#   bin/review-agent --pr 1234
#   bin/review-agent --file path/to/design-doc.md
#   bin/review-agent --pr 1234 --output-file review.md
set -euo pipefail

PR=""
FILE=""
OUTPUT_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pr) PR="$2"; shift 2 ;;
    --file) FILE="$2"; shift 2 ;;
    --output-file) OUTPUT_FILE="$2"; shift 2 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$PR" && -z "$FILE" ]]; then
  echo "Usage: review-agent --pr <number> | --file <path> [--output-file <path>]" >&2
  exit 1
fi

if [[ -n "$PR" ]]; then
  INPUT="Please review GitHub PR #${PR} with Staff-level framing."
elif [[ -n "$FILE" ]]; then
  if [[ ! -f "$FILE" ]]; then
    echo "File not found: $FILE" >&2
    exit 1
  fi
  INPUT=$(cat "$FILE")
fi

if [[ -n "$OUTPUT_FILE" ]]; then
  printf '%s' "$INPUT" | claude -p --profile reviewer-agent --output-file "$OUTPUT_FILE"
  echo "Written to $OUTPUT_FILE" >&2
else
  printf '%s' "$INPUT" | claude -p --profile reviewer-agent
fi
