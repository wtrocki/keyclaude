#!/usr/bin/env bash
# rewrite-reply — polish a PR/doc comment reply via the reviewer-agent profile.
#
# Usage:
#   echo "my reply text" | bin/rewrite-reply
#   pbpaste | bin/rewrite-reply          # paste full thread + reply
#
# Result is copied to clipboard. Glass sound + notification on completion.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

INPUT=$(cat)
if [[ -z "$INPUT" ]]; then
  echo "Error: no input text" >&2
  exit 1
fi

cd "$REPO_ROOT"
RESULT=$(printf '%s' "$INPUT" | claude -p --profile reviewer-agent --tools "")
printf '%s' "$RESULT" | pbcopy

afplay /System/Library/Sounds/Glass.aiff &
osascript -e 'display notification "Reply copied to clipboard." with title "Rewrite: Reply"' &
