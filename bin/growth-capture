#!/usr/bin/env bash
# growth-capture — pipe a growth input through growth-notes and bragsheet-entry.
# The bragsheet row (if a signal is found) is appended to docs/bragsheet.md.
#
# Usage:
#   pbpaste | bin/growth-capture
#   bin/growth-capture < slack-thread.txt
#   bin/growth-capture --append-file ~/custom/bragsheet.md < input.txt
#   bin/growth-capture --output-file growth-note.md < input.txt
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
DATA_ROOT="${GROWTH_REPO:-$REPO_ROOT/../engineering-notes}"
APPEND_FILE="${APPEND_FILE:-$DATA_ROOT/bragsheet.md}"
OUTPUT_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --append-file) APPEND_FILE="$2"; shift 2 ;;
    --output-file) OUTPUT_FILE="$2"; shift 2 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

INPUT=$(cat)

echo "=== Growth Notes ===" >&2
if [[ -n "$OUTPUT_FILE" ]]; then
  printf '%s' "$INPUT" | claude -p --profile growth-agent --skill growth-notes --output-file "$OUTPUT_FILE"
else
  printf '%s' "$INPUT" | claude -p --profile growth-agent --skill growth-notes
fi

echo "" >&2
echo "=== Bragsheet Entry ===" >&2
printf '%s' "$INPUT" | claude -p --profile growth-agent --skill bragsheet-entry --append-file "$APPEND_FILE"
