#!/usr/bin/env bash
# weekly-init — create a new weekly note with the standard template.
#
# Usage:
#   bin/weekly-init            # auto-detects current ISO week (e.g. 2026-W18)
#   bin/weekly-init 2026-W19   # specify week explicitly
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
DATA_ROOT="${GROWTH_REPO:-$REPO_ROOT/../engineering-notes}"
WEEKLY_DIR="$DATA_ROOT/weekly"

if [[ $# -ge 1 ]]; then
  WEEK="$1"
else
  WEEK=$(date +"%Y-W%V")
fi

FILE="$WEEKLY_DIR/${WEEK}.md"

if [[ -f "$FILE" ]]; then
  echo "Weekly note already exists: $FILE" >&2
  exit 1
fi

mkdir -p "$WEEKLY_DIR"

cat > "$FILE" << EOF
# Week ${WEEK}

> Week priorities: <!-- copy your current week priorities here -->

## Planned

-

## Done

-

## Blockers / Risks

-

## Cross-team

-

## Notes

-

## Impact Items

> <!-- High-impact work that surfaced this week. For each: does it fit priorities? Is there capacity? -->

-

EOF

echo "Created: $FILE"
